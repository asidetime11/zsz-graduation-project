<!doctype html>
<html>
<head><meta charset="utf-8"><title>Patient Register</title></head>
<body>
<h2>在线问诊预约注册</h2>
<form action="/api/register" method="post">
    <input name="name" placeholder="name" />
    <input name="id_card" placeholder="id_card" />
    <input name="phone" placeholder="phone" />
    <input name="medical_insurance_no" placeholder="medical_insurance_no" />
    <input name="emergency_contact" placeholder="emergency_contact" />
    <input name="family_income" placeholder="family_income" />
    <input name="religion" placeholder="religion" />
    <button type="submit">submit</button>
</form>
</body>
</html>
